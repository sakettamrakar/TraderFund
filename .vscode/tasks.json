{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Ingestion Cycle",
      "type": "shell",
      "command": "python",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [
        "-m",
        "ingestion.api_ingestion.angel_smartapi.market_data_ingestor"
      ],
      "group": "build"
    },
    {
      "label": "Run Processing Cycle",
      "type": "shell",
      "command": "python",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [
        "processing/intraday_candles_processor.py"
      ],
      "group": "build"
    },
    {
      "label": "Start Dashboard API",
      "type": "shell",
      "command": "python",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "args": [
        "scripts/start_dashboard_api.py",
        "--reload"
      ],
      "isBackground": true,
      "group": "build"
    },
    {
      "label": "Start Dashboard Frontend",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "dev"
      ],
      "options": {
        "cwd": "${workspaceFolder}/src/dashboard/frontend"
      },
      "isBackground": true,
      "group": "build"
    }
  ]
}